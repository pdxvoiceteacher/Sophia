{
  "schema": "policy_thresholds_v1",
  "network_profile": "witness_only",
  "consensus_requirements": {
    "min_total_attestations": 1,
    "min_weighted_pass": 1.0,
    "block_on_any_fail": true,
    "allow_pending_to_satisfy": false
  },
  "export_policy": {
    "require_convergent": true,
    "require_attestations": true,
    "allowed_formats": [
      "json"
    ]
  },
  "notes": "Conservative defaults: require at least one attestation and treat pending as non-satisfying."
}

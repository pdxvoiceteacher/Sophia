{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NavigationAuditRecord",
  "type": "object",
  "required": ["finding", "severity", "advisory", "semanticMode", "created_at"],
  "properties": {
    "finding": {"type": "string"},
    "severity": {"enum": ["info", "warn"]},
    "advisory": {"enum": ["watch", "docket"]},
    "target": {"type": "string"},
    "semanticMode": {"const": "non-executive"},
    "created_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}

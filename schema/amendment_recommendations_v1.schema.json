{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sophia/schema/amendment_recommendations_v1.schema.json",
  "title": "Amendment Recommendations v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "created_at", "phaselock", "caution", "recommendations"],
  "properties": {
    "schema": {"const": "amendment_recommendations_v1"},
    "created_at": {"type": "string"},
    "phaselock": {"type": "string"},
    "caution": {"type": "string"},
    "recommendations": {
      "type": "array",
      "items": {"$ref": "#/$defs/record"}
    }
  },
  "$defs": {
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "amendmentId",
        "quorumStatus",
        "amendmentStatus",
        "coherenceScore",
        "riskScore",
        "antiCaptureRisk",
        "conflictContext",
        "continuityModeContext",
        "governingRule",
        "explanation",
        "targetPublisherAction"
      ],
      "properties": {
        "amendmentId": {"type": "string"},
        "quorumStatus": {"enum": ["sufficient", "strained", "stacked-risk", "insufficient", "indeterminate"]},
        "amendmentStatus": {
          "enum": [
            "recommend-deliberation",
            "hold",
            "watch",
            "reject-amendment",
            "require-broader-human-review",
            "emergency-interpretation-only"
          ]
        },
        "coherenceScore": {"type": "number", "minimum": 0, "maximum": 1},
        "riskScore": {"type": "number", "minimum": 0, "maximum": 1},
        "antiCaptureRisk": {"type": "number", "minimum": 0, "maximum": 1},
        "conflictContext": {"type": "object", "additionalProperties": true},
        "continuityModeContext": {"type": "object", "additionalProperties": true},
        "governingRule": {"type": "string"},
        "explanation": {"type": "string"},
        "targetPublisherAction": {"enum": ["docket", "watch", "suppress"]}
      }
    }
  }
}

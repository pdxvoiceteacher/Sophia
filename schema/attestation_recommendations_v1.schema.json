{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sophia/schema/attestation_recommendations_v1.schema.json",
  "title": "Attestation Recommendations v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "created_at", "phaselock", "caution", "recommendations"],
  "properties": {
    "schema": {"const": "attestation_recommendations_v1"},
    "created_at": {"type": "string"},
    "phaselock": {"type": "string"},
    "caution": {"type": "string"},
    "recommendations": {"type": "array", "items": {"$ref": "#/$defs/record"}}
  },
  "$defs": {
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attestationId",
        "witnessStatus",
        "attestationStatus",
        "coherenceScore",
        "riskScore",
        "tamperRisk",
        "antiCaptureRisk",
        "continuityContext",
        "governingRule",
        "explanation",
        "targetPublisherAction"
      ],
      "properties": {
        "attestationId": {"type": "string"},
        "witnessStatus": {"enum": ["sufficient", "strained", "stacked-risk", "insufficient", "indeterminate"]},
        "attestationStatus": {
          "enum": [
            "docket-for-witness",
            "watch",
            "hold",
            "reject-attestation",
            "require-broader-human-review"
          ]
        },
        "coherenceScore": {"type": "number", "minimum": 0, "maximum": 1},
        "riskScore": {"type": "number", "minimum": 0, "maximum": 1},
        "tamperRisk": {"type": "number", "minimum": 0, "maximum": 1},
        "antiCaptureRisk": {"type": "number", "minimum": 0, "maximum": 1},
        "continuityContext": {"type": "object", "additionalProperties": true},
        "governingRule": {"type": "string"},
        "explanation": {"type": "string"},
        "targetPublisherAction": {"enum": ["docket", "watch", "suppress"]}
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sophia/schema/commons_sovereignty_audit_v1.schema.json",
  "title": "Commons Sovereignty Audit v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "created_at", "caution", "metadata", "records"],
  "properties": {
    "schema": {"const": "commons_sovereignty_audit_v1"},
    "created_at": {"type": "string"},
    "caution": {"type": "string"},
    "metadata": {"$ref": "#/$defs/metadata"},
    "records": {"type": "array", "items": {"$ref": "#/$defs/record"}}
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inputMode", "inputModeWarning", "systemRisk", "inputArtifacts", "supportingAudits"],
      "properties": {
        "inputMode": {"enum": ["live", "fixture", "mixed"]},
        "inputModeWarning": {"type": "string"},
        "systemRisk": {"type": "number", "minimum": 0, "maximum": 1},
        "inputArtifacts": {"type": "array", "minItems": 4, "items": {"$ref": "#/$defs/inputArtifact"}},
        "supportingAudits": {"type": "array", "minItems": 5, "maxItems": 5, "items": {"type": "string"}}
      }
    },
    "inputArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sourceMode", "schemaVersion", "producerRepo", "producerModule", "producerCommit", "generatedAt"],
      "properties": {
        "path": {"type": "string"},
        "sourceMode": {"enum": ["canonical", "compatibility"]},
        "schemaVersion": {"type": "string"},
        "producerRepo": {"type": "string"},
        "producerModule": {"type": "string"},
        "producerCommit": {"type": "string"},
        "generatedAt": {"type": "string"}
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targetId",
        "targetType",
        "sovereigntyStatus",
        "coherenceScore",
        "riskScore",
        "federationContext",
        "trustContext",
        "captureContext",
        "governingRule",
        "explanation",
        "targetPublisherAction"
      ],
      "properties": {
        "targetId": {"type": "string"},
        "targetType": {"type": "string"},
        "sovereigntyStatus": {"enum": ["commons-stable", "repair-priority", "capture-risk", "trust-collapse-risk", "require-human-review"]},
        "coherenceScore": {"type": "number", "minimum": 0, "maximum": 1},
        "riskScore": {"type": "number", "minimum": 0, "maximum": 1},
        "federationContext": {"type": "string"},
        "trustContext": {"type": "string"},
        "captureContext": {"type": "string"},
        "governingRule": {"type": "string"},
        "explanation": {"type": "string"},
        "targetPublisherAction": {"enum": ["docket", "watch", "suppress"]}
      }
    }
  }
}

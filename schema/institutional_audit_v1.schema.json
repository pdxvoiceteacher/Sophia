{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sophia/schema/institutional_audit_v1.schema.json",
  "title": "Institutional Audit v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "created_at", "phaselock", "caution", "records"],
  "properties": {
    "schema": {"const": "institutional_audit_v1"},
    "created_at": {"type": "string"},
    "phaselock": {"type": "string"},
    "caution": {"type": "string"},
    "records": {"type": "array", "items": {"$ref": "#/$defs/record"}}
  },
  "$defs": {
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "institutionId",
        "institutionalStatus",
        "synthesisScore",
        "riskScore",
        "conflictScore",
        "healthScore",
        "governingRule",
        "explanation",
        "targetPublisherAction"
      ],
      "properties": {
        "institutionId": {"type": "string"},
        "institutionalStatus": {
          "enum": [
            "stable",
            "monitor",
            "caution",
            "freeze-pathways",
            "require-human-review",
            "preservation-mode"
          ]
        },
        "synthesisScore": {"type": "number", "minimum": 0, "maximum": 1},
        "riskScore": {"type": "number", "minimum": 0, "maximum": 1},
        "conflictScore": {"type": "number", "minimum": 0, "maximum": 1},
        "healthScore": {"type": "number", "minimum": 0, "maximum": 1},
        "governingRule": {"type": "string"},
        "explanation": {"type": "string"},
        "targetPublisherAction": {"enum": ["docket", "watch", "suppress"]}
      }
    }
  }
}

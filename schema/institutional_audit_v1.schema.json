{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sophia/schema/institutional_audit_v1.schema.json",
  "title": "Institutional Audit v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "created_at", "phaselock", "caution", "metadata", "records"],
  "properties": {
    "schema": {"const": "institutional_audit_v1"},
    "created_at": {"type": "string"},
    "phaselock": {"type": "string"},
    "caution": {"type": "string"},
    "metadata": {"$ref": "#/$defs/metadata"},
    "records": {"type": "array", "items": {"$ref": "#/$defs/record"}}
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inputMode", "inputModeWarning", "phaselockContractStatus", "inputArtifacts"],
      "properties": {
        "inputMode": {"enum": ["live", "fixture", "mixed"]},
        "inputModeWarning": {"type": "string"},
        "phaselockContractStatus": {"type": "string"},
        "inputArtifacts": {
          "type": "array",
          "items": {"$ref": "#/$defs/inputArtifact"},
          "minItems": 4
        }
      }
    },
    "inputArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sourceMode",
        "schemaVersion",
        "producerRepo",
        "producerModule",
        "producerCommit",
        "generatedAt"
      ],
      "properties": {
        "path": {"type": "string"},
        "sourceMode": {"enum": ["canonical", "compatibility"]},
        "schemaVersion": {"type": "string"},
        "producerRepo": {"type": "string"},
        "producerModule": {"type": "string"},
        "producerCommit": {"type": "string"},
        "generatedAt": {"type": "string"}
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "institutionId",
        "institutionalStatus",
        "synthesisScore",
        "riskScore",
        "conflictScore",
        "healthScore",
        "governingRule",
        "explanation",
        "targetPublisherAction"
      ],
      "properties": {
        "institutionId": {"type": "string"},
        "institutionalStatus": {
          "enum": [
            "stable",
            "monitor",
            "caution",
            "freeze-pathways",
            "require-human-review",
            "preservation-mode"
          ]
        },
        "synthesisScore": {"type": "number", "minimum": 0, "maximum": 1},
        "riskScore": {"type": "number", "minimum": 0, "maximum": 1},
        "conflictScore": {"type": "number", "minimum": 0, "maximum": 1},
        "healthScore": {"type": "number", "minimum": 0, "maximum": 1},
        "governingRule": {"type": "string"},
        "explanation": {"type": "string"},
        "targetPublisherAction": {"enum": ["docket", "watch", "suppress"]}
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sophia/schema/precedent_audit_v1.schema.json",
  "title": "Precedent Audit v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "created_at", "phaselock", "caution", "records"],
  "properties": {
    "schema": {"const": "precedent_audit_v1"},
    "created_at": {"type": "string"},
    "phaselock": {"type": "string"},
    "caution": {"type": "string"},
    "records": {"type": "array", "items": {"$ref": "#/$defs/record"}}
  },
  "$defs": {
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "caseId",
        "precedentStatus",
        "coherenceScore",
        "riskScore",
        "divergenceLevel",
        "antiCaptureRisk",
        "governingRule",
        "explanation",
        "targetPublisherAction"
      ],
      "properties": {
        "caseId": {"type": "string"},
        "precedentStatus": {
          "enum": [
            "follow-precedent",
            "distinguish-case",
            "watch-divergence",
            "reject-analogy",
            "require-broader-human-review"
          ]
        },
        "coherenceScore": {"type": "number", "minimum": 0, "maximum": 1},
        "riskScore": {"type": "number", "minimum": 0, "maximum": 1},
        "divergenceLevel": {"type": "number", "minimum": 0, "maximum": 1},
        "antiCaptureRisk": {"type": "number", "minimum": 0, "maximum": 1},
        "governingRule": {"type": "string"},
        "explanation": {"type": "string"},
        "targetPublisherAction": {"enum": ["docket", "watch", "suppress"]}
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sophia/schema/resilience_audit_v1.schema.json",
  "title": "Resilience Audit v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "created_at", "phaselock", "caution", "records"],
  "properties": {
    "schema": {"const": "resilience_audit_v1"},
    "created_at": {"type": "string"},
    "phaselock": {"type": "string"},
    "caution": {"type": "string"},
    "records": {
      "type": "array",
      "items": {"$ref": "#/$defs/record"}
    }
  },
  "$defs": {
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resilienceStatus",
        "auditStatus",
        "coherenceScore",
        "riskScore",
        "quorumDepthContext",
        "antiCaptureRisk",
        "governanceFragilityContext",
        "governingRule",
        "explanation",
        "targetPublisherAction"
      ],
      "oneOf": [
        {"required": ["resilienceId"]},
        {"required": ["reviewerId"]}
      ],
      "properties": {
        "resilienceId": {"type": "string"},
        "reviewerId": {"type": "string"},
        "resilienceStatus": {"enum": ["stable", "thinning", "fragile", "capture-risk", "degraded"]},
        "auditStatus": {
          "enum": [
            "continue",
            "queue-continuity-review",
            "increase-watch",
            "freeze-governance-expansion",
            "degraded-mode",
            "require-human-emergency-review"
          ]
        },
        "coherenceScore": {"type": "number", "minimum": 0, "maximum": 1},
        "riskScore": {"type": "number", "minimum": 0, "maximum": 1},
        "quorumDepthContext": {"type": "object", "additionalProperties": true},
        "antiCaptureRisk": {"type": "number", "minimum": 0, "maximum": 1},
        "governanceFragilityContext": {"type": "object", "additionalProperties": true},
        "governingRule": {"type": "string"},
        "explanation": {"type": "string"},
        "targetPublisherAction": {"enum": ["docket", "watch", "suppress"]}
      }
    }
  }
}

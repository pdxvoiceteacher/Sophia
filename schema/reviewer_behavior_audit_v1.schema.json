{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sophia/schema/reviewer_behavior_audit_v1.schema.json",
  "title": "Reviewer Behavior Audit v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "created_at", "phaselock", "caution", "reviewers"],
  "properties": {
    "schema": {"const": "reviewer_behavior_audit_v1"},
    "created_at": {"type": "string"},
    "phaselock": {"type": "string"},
    "caution": {"type": "string"},
    "reviewers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "reviewerId",
          "continuedEligibilityStatus",
          "behaviorTrend",
          "overrideRisk",
          "coherenceAlignment",
          "humanReviewFlag",
          "explanation"
        ],
        "properties": {
          "reviewerId": {"type": "string"},
          "continuedEligibilityStatus": {"enum": ["continue", "watch", "re-review", "suspend-pending-review"]},
          "behaviorTrend": {"type": "string"},
          "overrideRisk": {"type": "number", "minimum": 0, "maximum": 1},
          "coherenceAlignment": {"type": "number", "minimum": 0, "maximum": 1},
          "humanReviewFlag": {"type": "boolean"},
          "explanation": {"type": "string"}
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sophia/schema/rupture_audit_v1.schema.json",
  "title": "Rupture Audit v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "created_at", "caution", "decision", "findings"],
  "properties": {
    "schema": {"const": "rupture_audit_v1"},
    "created_at": {"type": "string"},
    "caution": {"type": "string"},
    "decision": {"enum": ["pass", "warn"]},
    "findings": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/finding"}}
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "severity", "type", "advisory", "message", "data"],
      "properties": {
        "id": {"type": "string"},
        "severity": {"enum": ["info", "warn"]},
        "type": {"type": "string"},
        "advisory": {"enum": ["watch", "docket"]},
        "message": {"type": "string"},
        "data": {"type": "object"}
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sophia/schema/schism_audit_v1.schema.json",
  "title": "Schism Audit v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "created_at", "caution", "decision", "findings"],
  "properties": {
    "schema": {"const": "schism_audit_v1"},
    "created_at": {"type": "string"},
    "caution": {"type": "string"},
    "decision": {"enum": ["pass", "warn"]},
    "findings": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/finding"}}
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "severity", "type", "message", "advisory", "data"],
      "properties": {
        "id": {"type": "string"},
        "severity": {"type": "string", "enum": ["warn", "info"]},
        "type": {"type": "string", "enum": ["schism-risk", "within-bounds", "missing-data"]},
        "message": {"type": "string"},
        "advisory": {"type": "string", "enum": ["watch", "docket"]},
        "data": {"type": "object"}
      }
    }
  }
}

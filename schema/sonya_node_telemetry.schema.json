{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coherencelattice.dev/schema/sonya_node_telemetry.schema.json",
  "title": "Sonya Node Telemetry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "node_id",
    "task_id",
    "timestamp",
    "status",
    "artifacts"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "sonya_node_telemetry_v1"
    },
    "node_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["success", "failed"]
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "E":      { "type": "number" },
        "T":      { "type": "number" },
        "Psi":    { "type": "number" },
        "DeltaS": { "type": "number" },
        "Lambda": { "type": "number" },
        "Es":     { "type": "number" }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "signature": {
      "type": "string"
    }
  }
}

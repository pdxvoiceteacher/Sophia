{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sonya_node_telemetry.schema.json",
  "title": "Sonya Node Telemetry v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "node_id",
    "task_id",
    "timestamp",
    "metrics",
    "status",
    "artifacts"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "sonya_node_telemetry_v1"
    },
    "node_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "E": {
          "type": "number"
        },
        "T": {
          "type": "number"
        },
        "Ψ": {
          "type": "number"
        },
        "ΔS": {
          "type": "number"
        },
        "Λ": {
          "type": "number"
        },
        "Eₛ": {
          "type": "number"
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "failed"
      ]
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}

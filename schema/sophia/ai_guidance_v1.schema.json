{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sophia/schema/sophia/ai_guidance_v1.schema.json",
  "title": "AI Guidance v1 (Advisory-only)",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "created_at", "caution", "modifiers"],
  "properties": {
    "schema": {"const": "sophia/ai_guidance_v1"},
    "created_at": {"type": "string"},
    "caution": {"type": "string", "minLength": 16, "maxLength": 4000},
    "modifiers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "increase_plural_exploration",
          "increase_cross_domain_bridging",
          "increase_epistemic_transparency",
          "increase_uncertainty_marking",
          "avoid_canon_language",
          "reduce_premature_convergence",
          "request_human_review"
        ]
      }
    },
    "inputs": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}

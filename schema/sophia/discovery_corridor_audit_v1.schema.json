{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Discovery Corridor Audit",
  "type": "object",
  "required": ["schema", "created_at", "caution", "decision", "findings"],
  "properties": {
    "schema": {"type": "string", "const": "sophia/discovery_corridor_audit_v1"},
    "created_at": {"type": "string"},
    "caution": {"type": "string"},
    "decision": {"type": "string", "enum": ["info", "warn"]},
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "severity", "type", "advisory", "message", "data"],
        "properties": {
          "id": {"type": "string"},
          "severity": {"type": "string", "enum": ["info", "warn"]},
          "type": {"type": "string"},
          "advisory": {"type": "string", "enum": ["watch", "docket"]},
          "message": {"type": "string"},
          "data": {"type": "object"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

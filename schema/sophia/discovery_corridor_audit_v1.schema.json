{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Discovery Corridor Audit V1",
  "type": "object",
  "required": ["findings"],
  "properties": {
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "type", "advisory", "message", "data"],
        "properties": {
          "id": {"type": "string"},
          "severity": {"type": "string", "enum": ["info", "warn"]},
          "type": {"type": "string"},
          "advisory": {"type": "string", "enum": ["watch", "docket"]},
          "message": {"type": "string"},
          "data": {"type": "object"}
        }
      }
    }
  }
}

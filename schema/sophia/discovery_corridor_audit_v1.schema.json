{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sophia/schema/sophia/discovery_corridor_audit_v1.schema.json",
  "title": "Discovery Corridor Audit v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "created_at", "caution", "decision", "findings"],
  "properties": {
    "schema": {"const": "sophia/discovery_corridor_audit_v1"},
    "created_at": {"type": "string"},
    "caution": {"type": "string", "minLength": 16, "maxLength": 4000},
    "decision": {"type": "string", "enum": ["info", "warn"]},
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/finding"}
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "severity", "type", "advisory", "message", "data"],
      "properties": {
        "id": {"type": "string", "minLength": 3, "maxLength": 128},
        "severity": {"type": "string", "enum": ["info", "warn"]},
        "type": {"type": "string", "enum": ["audit"]},
        "advisory": {"type": "string", "enum": ["watch", "docket"]},
        "message": {"type": "string", "minLength": 8, "maxLength": 2000},
        "data": {"type": "object"}
      }
    }
  }
}

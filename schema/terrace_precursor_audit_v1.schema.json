{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sophia/schema/terrace_precursor_audit_v1.schema.json",
  "title": "Terrace Precursor Audit v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "created_at", "phaselock", "caution", "metadata", "decision", "findings"],
  "properties": {
    "schema": {"const": "terrace_precursor_audit_v1"},
    "created_at": {"type": "string"},
    "phaselock": {"type": "string"},
    "caution": {"type": "string"},
    "metadata": {"$ref": "#/$defs/metadata"},
    "decision": {"enum": ["pass", "warn"]},
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/finding"}
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inputArtifact", "targetCount", "warningCount", "infoCount"],
      "properties": {
        "inputArtifact": {"const": "bridge/terrace_precursor_map.json"},
        "targetCount": {"type": "integer", "minimum": 1},
        "warningCount": {"type": "integer", "minimum": 0},
        "infoCount": {"type": "integer", "minimum": 0}
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["targetId", "severity", "type", "message", "targetPublisherAction", "data"],
      "properties": {
        "targetId": {"type": "string"},
        "severity": {"enum": ["info", "warn"]},
        "type": {"type": "string"},
        "message": {"type": "string"},
        "targetPublisherAction": {"enum": ["watch", "docket"]},
        "data": {"type": "object"}
      }
    }
  }
}

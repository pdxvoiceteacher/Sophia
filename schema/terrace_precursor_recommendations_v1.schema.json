{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sophia/schema/terrace_precursor_recommendations_v1.schema.json",
  "title": "Terrace Precursor Recommendations v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "created_at", "phaselock", "caution", "metadata", "recommendations"],
  "properties": {
    "schema": {"const": "terrace_precursor_recommendations_v1"},
    "created_at": {"type": "string"},
    "phaselock": {"type": "string"},
    "caution": {"type": "string"},
    "metadata": {"$ref": "#/$defs/metadata"},
    "recommendations": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/recommendation"}
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inputArtifact", "targetCount", "warningCount", "infoCount"],
      "properties": {
        "inputArtifact": {"const": "bridge/terrace_precursor_map.json"},
        "targetCount": {"type": "integer", "minimum": 1},
        "warningCount": {"type": "integer", "minimum": 0},
        "infoCount": {"type": "integer", "minimum": 0}
      }
    },
    "recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["targetId", "type", "recommendation", "targetPublisherAction"],
      "properties": {
        "targetId": {"type": "string"},
        "type": {"type": "string"},
        "recommendation": {"type": "string"},
        "targetPublisherAction": {"enum": ["watch", "docket"]}
      }
    }
  }
}

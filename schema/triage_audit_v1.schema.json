{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sophia/schema/triage_audit_v1.schema.json",
  "title": "Triage Audit v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "created_at", "phaselock", "caution", "metadata", "records"],
  "properties": {
    "schema": {"const": "triage_audit_v1"},
    "created_at": {"type": "string"},
    "phaselock": {"type": "string"},
    "caution": {"type": "string"},
    "metadata": {"$ref": "#/$defs/metadata"},
    "records": {"type": "array", "items": {"$ref": "#/$defs/record"}}
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inputMode", "inputModeWarning", "systemRisk", "inputArtifacts"],
      "properties": {
        "inputMode": {"enum": ["live", "fixture", "mixed"]},
        "inputModeWarning": {"type": "string"},
        "systemRisk": {"type": "number", "minimum": 0, "maximum": 1},
        "inputArtifacts": {"type": "array", "minItems": 4, "items": {"$ref": "#/$defs/inputArtifact"}}
      }
    },
    "inputArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sourceMode", "schemaVersion", "producerRepo", "producerModule", "producerCommit", "generatedAt"],
      "properties": {
        "path": {"type": "string"},
        "sourceMode": {"enum": ["canonical", "compatibility"]},
        "schemaVersion": {"type": "string"},
        "producerRepo": {"type": "string"},
        "producerModule": {"type": "string"},
        "producerCommit": {"type": "string"},
        "generatedAt": {"type": "string"}
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["targetId", "targetType", "triageStatus", "coherenceScore", "riskScore", "urgencyContext", "queueContext", "captureContext", "reversibilityContext", "governingRule", "explanation", "targetPublisherAction"],
      "properties": {
        "targetId": {"type": "string"},
        "targetType": {"type": "string"},
        "triageStatus": {"enum": ["immediate-review", "near-term-review", "monitor", "defer", "freeze-dependent-pathways", "require-human-review"]},
        "coherenceScore": {"type": "number", "minimum": 0, "maximum": 1},
        "riskScore": {"type": "number", "minimum": 0, "maximum": 1},
        "urgencyContext": {"type": "string"},
        "queueContext": {"type": "string"},
        "captureContext": {"type": "string"},
        "reversibilityContext": {"type": "string"},
        "governingRule": {"type": "string"},
        "explanation": {"type": "string"},
        "targetPublisherAction": {"enum": ["docket", "watch", "suppress"]}
      }
    }
  }
}
